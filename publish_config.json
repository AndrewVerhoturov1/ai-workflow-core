{
  "repo": "AndrewVerhoturov1/ai-workflow-core",
  "branch": "main",
  "raw_url_template": "https://raw.githubusercontent.com/{repo}/{branch}/{path}",
  "blob_url_template": "https://github.com/{repo}/blob/{branch}/{path}",
  "description": "Central workflow core publish config. Явный replacement для .ai/public_core/public_core_publish_config.json в consumer repos. Consumer repo не хранит у себя publish-config для central core — он живёт только здесь.",
  "required_published_files": [
    "README.md",
    "AGENTS.md",
    "external_chat_rules.md",
    "repo_navigation.md",
    "ai_readme.md",
    "publish_config.json",
    "prompts/create_external_question_prompt.md",
    "prompts/choose_model.md",
    "prompts/create_handoff.md",
    "prompts/create_external_chat_request.md",
    "prompts/create_block_plan.md",
    "prompts/create_block_orchestrator_package.md",
    "prompts/record_external_chat_response.md",
    "prompts/record_external_notebook_response.md",
    "prompts/review_agent_report.md",
    "prompts/review_block_report.md",
    "rules/agent_protocol.md",
    "rules/model_roster.md",
    "rules/codex_orchestrator.md",
    "rules/kilo_mode_contract.md",
    "rules/kilo_builder.md",
    "rules/kilo_debugger.md",
    "rules/kilo_docs.md",
    "rules/kilo_refactor.md",
    "rules/kilo_tester.md",
    "external_chat/manual.md",
    "external_chat/external_agent_static_manual.md",
    "external_chat/tasks/README.md",
    "validators/README.md",
    "plans/README.md",
    "bootstrap/portable/README.md",
    "bootstrap/portable/manifest.md",
    "bootstrap/portable/copy_map.md",
    "bootstrap/portable/manual_setup_checklist.md",
    "bootstrap/portable/verification_checklist.md"
  ],
  "note": "publish-config-only. Concrete working file URLs подтверждаются только после реальной публикации файлов в repo. Scripts и templates не включены в required_published_files — они используются через локальное копирование, а не через raw URL."
}
